{
  "name": "@exileum/meta-mcp",
  "version": "3.3.1",
  "mcpName": "io.github.exileum/meta",
  "description": "Enables AI assistants to manage Instagram and Threads accounts — publish content, handle comments, view insights, search hashtags, and manage DMs through the Meta Graph API",
  "type": "module",
  "bin": {
    "meta-mcp": "dist/index.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist/**/*",
    "LICENSE",
    "README.md"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "mcp",
    "meta",
    "instagram",
    "threads",
    "graph-api",
    "model-context-protocol",
    "ai",
    "claude"
  ],
  "author": "Yury Pikhtarev",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/exileum/meta-mcp.git"
  },
  "homepage": "https://github.com/exileum/meta-mcp",
  "bugs": {
    "url": "https://github.com/exileum/meta-mcp/issues"
  },
  "publishConfig": {
    "provenance": true,
    "access": "public"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
