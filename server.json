{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.exileum/meta",
  "description": "Enables AI assistants to manage Instagram and Threads accounts — publish content, handle comments, view insights, search hashtags, and manage DMs through the Meta Graph API",
  "repository": {
    "url": "https://github.com/exileum/meta-mcp",
    "source": "github"
  },
  "version": "3.7.0",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "@exileum/meta-mcp",
      "version": "3.7.0",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "name": "INSTAGRAM_ACCESS_TOKEN",
          "description": "Instagram Graph API access token",
          "isRequired": false,
          "format": "string",
          "isSecret": true
        },
        {
          "name": "INSTAGRAM_USER_ID",
          "description": "Instagram Business/Creator account ID",
          "isRequired": false,
          "format": "string",
          "isSecret": false
        },
        {
          "name": "THREADS_ACCESS_TOKEN",
          "description": "Threads API access token",
          "isRequired": false,
          "format": "string",
          "isSecret": true
        },
        {
          "name": "THREADS_USER_ID",
          "description": "Threads user ID",
          "isRequired": false,
          "format": "string",
          "isSecret": false
        },
        {
          "name": "META_APP_ID",
          "description": "Meta App ID for token/webhook tools",
          "isRequired": false,
          "format": "string",
          "isSecret": false
        },
        {
          "name": "META_APP_SECRET",
          "description": "Meta App Secret for token/webhook tools",
          "isRequired": false,
          "format": "string",
          "isSecret": true
        }
      ]
    }
  ]
}
